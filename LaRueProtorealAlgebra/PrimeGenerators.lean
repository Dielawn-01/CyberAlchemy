-- GENERATION: Every composite is built from the 13
-- ═══════════════════════════════════════════════════════════

/-- Silence (35) is generated by entropy(5) × light(7). -/
theorem silence_generated : 35 = 5 * 7 := by norm_num

/-- Death (30) is generated by space(2) × position(3) × entropy(5). -/
theorem death_generated : 30 = 2 * 3 * 5 := by norm_num

/-- Anti-time (42) is generated by space(2) × position(3) × light(7). -/
theorem antitime_generated : 42 = 2 * 3 * 7 := by norm_num

/-- Love (18) is generated by space(2) × position(3)². -/
theorem love_generated : 18 = 2 * 3 ^ 2 := by norm_num

/-- Fear (25) is generated by entropy(5)². -/
theorem fear_generated : 25 = 5 ^ 2 := by norm_num

/-- Spin (21) is generated by position(3) × light(7). -/
theorem spin_generated : 21 = 3 * 7 := by norm_num

/-- Singularity (24) is generated by space(2)³ × position(3). -/
theorem singularity_generated : 24 = 2 ^ 3 * 3 := by norm_num

/-- Order (38) is generated by space(2) × horizon(19). -/
theorem order_generated : 38 = 2 * 19 := by norm_num

/-- Darkness (36) is generated by space(2)² × position(3)². -/
theorem darkness_generated : 36 = 2 ^ 2 * 3 ^ 2 := by norm_num

/-- Non-locality (40) is generated by space(2)³ × entropy(5). -/
theorem nonlocality_generated : 40 = 2 ^ 3 * 5 := by norm_num

/-- 1 (time) is the empty product — generated by zero primes. -/
theorem time_is_unit : 1 = Nat.factorial 0 := by norm_num


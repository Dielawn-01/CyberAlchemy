\section{Falsifiable Predictions}
\label{sec:chrono-predictions}
% ════════════════════════════════════════════

\begin{enumerate}
\item \textbf{Chronometric grid superiority.}  For simulations spanning $>3$ temporal decades, uniform $\tau$-spacing (geometric in $t$) should produce lower numerical stiffness than uniform $t$-spacing.  Testable by comparing Jacobian condition numbers.

\item \textbf{Mellin spectral compression.}  Signals with scale-invariant structure (e.g., $1/f$ noise, turbulent cascades) should have sparser representations in the Mellin basis than in the Fourier basis.

\item \textbf{Geomagnetic reversal timing.}  If geomagnetic reversal intervals follow a log-normal or multiplicative process, their recurrence statistics should be simpler in $\tau$-coordinates than in $t$-coordinates.  The chronometric distance $d_\tau = \lambda_\Delta |\ln(t_i/t_j)|$ should produce tighter clustering than absolute time differences.
\end{enumerate}
